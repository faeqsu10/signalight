# 거래 환경: mock (모의투자) | prod (실전투자)
TRADING_ENV=mock

# 키움증권 API (openapi.kiwoom.com에서 발급)
KIWOOM_REST_API_KEY=your_api_key
KIWOOM_REST_API_SECRET=your_api_secret
KIWOOM_ACCOUNT_NO=your_account_no

# OpenDART (https://opendart.fss.or.kr/ 에서 발급)
DART_API_KEY=your_dart_api_key

# 텔레그램 봇
TELEGRAM_BOT_TOKEN=your_bot_token_here
TELEGRAM_CHAT_ID=your_signal_channel_chat_id_here
TELEGRAM_ADMIN_CHAT_ID=your_admin_dm_or_ops_chat_id_here
AUTO_TRADE_CHAT_ID=your_auto_trade_chat_id_here
LONG_TRADE_CHAT_ID=your_position_trade_chat_id_here
MEANREV_CHAT_ID=your_meanrev_trade_chat_id_here
